{
  "manifest_version": 3,
  "name": "Revizorro Diff",
  "version": "0.1.0",
  "description": "Подсветка diff между итерациями ревью на платформе Яндекс Практикум",
  "permissions": ["storage", "activeTab"],
  "content_scripts": [
    {
      "matches": ["https://admin.praktikum.yandex-team.ru/office/revisor-review/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
